DISCORD_TOKEN=
REDIS_URL=redis://127.0.0.1:6380
TEST_GUILD_ID=
# Password for Redis. Used by docker-compose to secure the Redis instance.
# Must match the value used in REDIS_URL when running inside Docker.
REDIS_PASSWORD=please_change_me
# Structured log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
